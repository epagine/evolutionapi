+  private async fetchChatsMysql(query: any) {
+    const remoteJid = query?.where?.remoteJid
+      ? query?.where?.remoteJid.includes('@')
+        ? query.where?.remoteJid
+        : createJid(query.where?.remoteJid)
+      : null;
+
+    const take = query?.take ?? 50;
+    const skip = query?.skip ?? 0;
+
+    const whereChat: { instanceId: string; remoteJid?: string } = {
+      instanceId: this.instanceId,
+    };
+
+    if (remoteJid) {
+      whereChat.remoteJid = remoteJid;
+    }
+
+    const chats = await this.prismaRepository.chat.findMany({
+      where: whereChat,
+      orderBy: { updatedAt: 'desc' },
+      take,
+      skip,
+    });
+
+    const mappedResults = await Promise.all(
+      chats.map(async (chat) => {
+        const contact = await this.prismaRepository.contact.findFirst({
+          where: { instanceId: this.instanceId, remoteJid: chat.remoteJid },
+        });
+
+        const lastMessage = await this.prismaRepository.message.findFirst({
+          where: {
+            instanceId: this.instanceId,
+            key: { path: '$.remoteJid', equals: chat.remoteJid },
+          },
+          orderBy: { messageTimestamp: 'desc' },
+        });
+
+        const messageKey = lastMessage?.key as { fromMe?: boolean } | null;
+        const windowStart = chat.createdAt;
+        const windowExpires = chat.createdAt
+          ? new Date(chat.createdAt.getTime() + 24 * 60 * 60 * 1000)
+          : null;
+        const windowActive = windowExpires ? windowExpires > new Date() : false;
+
+        const pushName = chat.remoteJid.includes('@g.us')
+          ? chat.name || contact?.pushName
+          : contact?.pushName || lastMessage?.pushName;
+
+        return {
+          id: contact?.id || null,
+          remoteJid: chat.remoteJid,
+          pushName,
+          profilePicUrl: contact?.profilePicUrl,
+          updatedAt: lastMessage
+            ? new Date(lastMessage.messageTimestamp * 1000)
+            : contact?.updatedAt || chat.updatedAt,
+          windowStart,
+          windowExpires,
+          windowActive,
+          lastMessage: lastMessage
+            ? this.cleanMessageData({
+                ...lastMessage,
+                pushName: messageKey?.fromMe ? 'Você' : lastMessage.pushName,
+              })
+            : undefined,
+          unreadCount: chat.unreadMessages,
+          isSaved: !!contact?.id,
+        };
+      }),
+    );
+
+    return mappedResults;
+  }
